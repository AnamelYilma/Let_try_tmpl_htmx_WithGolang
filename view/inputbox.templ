package view

templ inputbox(){
    <div class="">
        <form 
        hx-post="\add"  
        id="inpt-box"
        hx-trigger="submit"
        target="#list-container"
        >
            <input 
            type="text" 
            placeholder="Type here..." 
            id="inpt" 
            name="user-input"  />
            <button 
            type="button"
            >ADD</button>
        </form>
    </div>
}