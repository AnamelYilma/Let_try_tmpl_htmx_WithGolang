package view

import(
    "gootmplhtmx/model"
)

templ Fulpage(title string, task []model.TASK) {
	<!DOCTYPE html>
	<html lang="en">
		@header(title)
		<body>
			<div class="container">
				<div class="in-container">
					@inputbox()
					<div id="list-container">
						@Listing(task)
					</div>
				</div>
			</div>
		</body>
	</html>
}